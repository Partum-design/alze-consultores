Options -MultiViews
RewriteEngine On

# Canonical clean URLs (avoid exposing .html)
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+((servicios|contacto))\.html[\s?] [NC]
RewriteRule ^(servicios|contacto)\.html$ /$1 [R=301,L]

# Do not rewrite existing files or directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Clean routes -> HTML pages
RewriteRule ^$ index.html [L]
RewriteRule ^servicios/?$ servicios.html [L,NC]
RewriteRule ^contacto/?$ contacto.html [L,NC]
